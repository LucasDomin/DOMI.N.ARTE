# ───────────────────────────────────────────────────────────────
# DOMI.N.ARTE — Environment Variables
# Copy to .env.local (dev) or set in Vercel Project Settings (prod)
# ───────────────────────────────────────────────────────────────

# DATABASE (required)
# Local dev:
#   postgresql://postgres:postgres@127.0.0.1:5432/app_db
# Supabase (use the "Connection string" → "Transaction" pooler, port 6543,
# and append ?pgbouncer=true&connection_limit=1 for serverless):
#   postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db

# Force-disable SSL for local non-Docker setups (optional)
# DB_SSL=false

# ───────────────────────────────────────────────────────────────
# AUTH (admin panel) — CHANGE THESE IN PRODUCTION
# ───────────────────────────────────────────────────────────────
# Long random string used to sign session cookies (e.g. `openssl rand -hex 32`)
AUTH_SECRET=change-me-to-a-long-random-string
# Password to access /admin
ADMIN_PASSWORD=dominarte2025

# ───────────────────────────────────────────────────────────────
# SUPABASE (optional — enables Storage uploads for images/videos)
# Without these, uploads fall back to inline base64 (dev only, 2.5MB cap).
# ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=dominarte
